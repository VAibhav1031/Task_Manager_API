FROM python:3.14-slim 

WORKDIR /task_app

COPY . .


RUN apt-get update && apt-get install -y \
    postgresql-client \
    libpq-dev \
    gcc \
    python3-dev && \
    pip3 install uv && \
    uv sync && \
    rm -rf /var/lib/apt/lists/*


RUN chmod +x docker-entrypoint.prod.sh 

EXPOSE 5556

ENTRYPOINT ["./docker-entrypoint.prod.sh"]


